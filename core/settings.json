  "flags": {
    "$comment": "Each entry names the setting (by EPROM_* name, resolved through 'naming' above at load time - not by a fixed absolute file offset, since that offset moves with alignment) plus a bit position and a human label. LOWER (medium) confidence than the numeric settings table: bit meanings were resolved via VEConfigure's own UI form definitions, not re-derived from each file's own self-describing min/max the way numeric settings are.",
    "confidence": "medium",
    "items": [
      { "id": "EBIT_DisableCharge", "setting_name": "EPROM_FlagsWord0", "bit": 6, "label": "Disable charge" },
      { "id": "EBIT_EnableReducedFloat", "setting_name": "EPROM_FlagsWord0", "bit": 11, "label": "Storage mode (reduced float)" },
      { "id": "EBIT_WeakACInput", "setting_name": "EPROM_FlagsWord0", "bit": 14, "label": "Weak AC input" },
      { "id": "EBIT_LithiumBattery", "setting_name": "EPROM_FlagsWord2", "bit": 4, "label": "Lithium battery" }
    ]
  },

  "enums": {
    "$comment": "Raw integer value -> human label, keyed by EPROM_* setting name. Confidence matches the numeric settings table (high) since the enum values themselves are the same self-describing raw field, but the specific label wording is cross-referenced against VEConfigure's own UI, so it is reported at medium confidence like flags.",
    "confidence": "medium",
    "items": {
      "EPROM_ChargeCharacteristic": { "1": "Fixed", "2": "Adaptive", "3": "Adaptive+BatterySafe" }
    }
  }
}
