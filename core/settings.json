{
  "$comment": "Single source of truth for the .rvsc container/record format, the EPROM_* setting identifier table, known flag bits, and enum labels. Both rvsc.py (loaded at runtime) and docs/index.html (injected at build time by tools/build_web.py) derive every name/flag/enum from this file. Do not duplicate any of these literal tables elsewhere.",
  "format_version": 1,

  "tested_against": {
    "model": "MultiPlus 24/1200/25-16",
    "firmware": "2667558",
    "veconfigure": "1.33"
  },

  "sections": {
    "header": { "name": "VEConfig setting section file", "has_payload": false, "confidence": "high" },
    "mk2_info": { "name": "Mk2vscInfo", "has_payload": true, "confidence": "high" },
    "info": { "name": "BareSettingInfo", "has_payload": true, "confidence": "high" },
    "data": { "name": "BareSettingData", "has_payload": true, "confidence": "high" }
  },

  "record_layout": {
    "$comment": "BareSettingInfo is a packed array of fixed-size records, one per setting index, no padding. BareSettingData is a parallel packed array of raw u16 values, same index order.",
    "info_record_size": 10,
    "info_fields": ["scale", "offset", "default", "min", "max"],
    "info_field_types": { "scale": "i16", "offset": "i16", "default": "u16", "min": "u16", "max": "u16" },
    "data_record_size": 2,
    "data_field": "raw",
    "data_field_type": "u16",
    "endianness": "little",
    "confidence": "high"
  },

  "decode": {
    "$comment": "real = (raw + offset) / abs(scale) when scale < 0; real = (raw + offset) * scale when scale > 0; scale == 0 means the record has no linear numeric meaning (bitfield/reserved slot) and decodes to null. min/max/default must be run through this SAME transform before being compared to a decoded value - comparing a decoded value against undecoded raw min/max is a unit mismatch and was a real bug found during development.",
    "confidence": "high"
  },

  "alignment": {
    "$comment": "Neither array's start offset is fixed across files/firmware. The correct start is found by brute-force self-validation: try candidate offsets for both arrays and score each candidate by how well its decoded values fall within their own declared [min, max]. See ALGORITHM.md-equivalent notes in rvsc.py/build_web.py for why RANGE-WEIGHTED scoring (not raw match count, and not a fixed tie-break tolerance window) was chosen.",
    "algorithm": "range_weighted",
    "info_header_search_range": 10,
    "min_valid_record_fraction": 0.4,
    "confidence": "high (technique); per-file result must independently satisfy min_valid_record_fraction"
  },

  "naming": {
    "$comment": "Setting index i (i >= 1) maps to epron_names[i - 1]. Index 0 has no name in every file examined (it is an unused/sentinel record, verified by scale == 0). If a file has more records than epron_names entries, extras fall back to 'setting_<n>' - names are never invented.",
    "confidence": "high",
    "epron_names": [
      "EPROM_FlagsWord0", "EPROM_FlagsWord1", "EPROM_UBatAbs", "EPROM_UBatFloat",
      "EPROM_IBatBulk", "EPROM_UInvSetpoint", "EPROM_IMainsLimit", "EPROM_EqualiseQuarters",
      "EPROM_FloatDays", "EPROM_AbsorptionHours", "EPROM_ChargeCharacteristic", "EPROM_UBat2Low",
      "EPROM_UBat2LowMargin", "EPROM_NrOfSlaves", "EPROM_SpecialThreePhase", "EPROM_vsUsage",
